# ─────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────

# Default LLM model in provider/model format.
# Examples: "anthropic/claude-sonnet-4-6", "openai/gpt-5.4",
#           "gemini/gemini-2.5-pro", "ollama_chat/gemma4:26b".
# Leave blank to be prompted on first launch via the Settings page.
LLM_MODEL=""

# API keys per provider — set the one(s) matching your LLM_MODEL and any
# per-agent overrides below. Local providers like Ollama need no real key.
LLM_API_KEY_ANTHROPIC=""
LLM_API_KEY_OPENAI=""
LLM_API_KEY_GEMINI=""
LLM_API_KEY_OLLAMA_CHAT="ollama"

# ─────────────────────────────────────────────────────────────────────
# ROON (all optional — auto-discovery fills the gaps)
# ─────────────────────────────────────────────────────────────────────

# Roon Core URL. Omit to let Swarpius discover the Core on your network.
# Set this if auto-discovery fails — most commonly when running Swarpius
# inside Docker, where the container's network namespace may not see
# the host LAN's SOOD multicast (always the case on Docker Desktop for
# Windows/Mac; can also happen on Linux Docker depending on your bridge
# config). Supply the Core's LAN IP directly to bypass discovery.
# ROON_CORE_URL="http://192.168.1.100:9330"

# Roon Core name — only matters if more than one Core is on your network.
# When Swarpius's first-run discovery finds multiple Cores, it needs a way
# to choose one. Set this to the Core's name as it appears in the Roon
# app (Settings > General > ROON SERVER) and Swarpius will pair with that one.
# If only one Core is found, *or* ROON_CORE_URL is set, this is ignored.
# ROON_CORE_NAME="Living Room Core"

# Roon profile to set for Swarpius. Omit for Roon's default profile.
# Note: the Roon API does not reliably apply this, so the default profile
# is used in practice regardless.
# ROON_PROFILE_NAME="Peter"

# ─────────────────────────────────────────────────────────────────────
# OPTIONAL AGENT MODELS (default to LLM_MODEL)
# ─────────────────────────────────────────────────────────────────────

# Per-agent model overrides. The coordinator always uses LLM_MODEL;
# the arbiter, diagnostic, and analyser agents fall back to it unless overridden.
# LLM_MODEL_ARBITER="anthropic/claude-haiku-4-5"
# LLM_MODEL_DIAGNOSTIC="anthropic/claude-haiku-4-5"
# LLM_MODEL_ANALYSER="anthropic/claude-opus-4-6"

# ─────────────────────────────────────────────────────────────────────
# OPTIONAL FEATURES
# ─────────────────────────────────────────────────────────────────────

# Persona — character name or personality description injected into the
# coordinator's system prompt.
# Examples: "Peter Griffin", "Funny and sarcastic", "A wise British butler"
# LLM_PERSONA=""

# Diagnostic agent — LLM-driven conversation classification for log
# grouping. Default off. Enable if you plan to analyse traffic.
# ENABLE_DIAGNOSTIC_AGENT="false"

# Interrupt arbiter — when a new request arrives while another is in
# flight, an LLM call decides whether to queue, interrupt-and-replace,
# or interrupt-only. Default off. Set to "true" to use the arbiter
# (otherwise new requests just queue).
# ENABLE_INTERRUPT_ARBITER="false"

# Passive conversation analyser — LLM-driven retrospective quality
# analysis of completed conversations. Powers the analysis browser's
# Metrics / Re-Analyse / Scan & Analyse surfaces. Off by default;
# every analysis costs LLM tokens, so opt in once you're sure you
# want the spend. The "Scan & Analyse" and "Re-Analyse" buttons in
# the UI also work without the background loop — they perform a
# one-shot analysis under the same scan lock.
# ENABLE_PASSIVE_ANALYSER="false"

# How often the background loop scans for unanalysed conversations
# (minutes). Default 30. Only consulted when ENABLE_PASSIVE_ANALYSER
# is true.
# ANALYSER_INTERVAL_MINUTES="30"

# How long a conversation must be idle before the background loop
# considers it stable enough to analyse (minutes). Default 60.
# ANALYSER_STALENESS_MINUTES="60"

# Roon API Explorer — a developer-only panel for navigating raw
# Roon browse responses (search → browse → load) without any
# Swarpius abstraction on the call path. Hidden from the UI when
# unset. Set to "true" to enable.
# ENABLE_ROON_EXPLORER="false"

# ─────────────────────────────────────────────────────────────────────
# WEB SEARCH BACKEND (optional)
# ─────────────────────────────────────────────────────────────────────
# Lets the coordinator look up facts the Roon library cannot answer
# (genres, eras, "most popular UK song from 1976", etc). Optional —
# Swarpius runs fine without web search - but highly recommended for
# a better experience. If you don't set this up, the coordinator will
# attempt to answer using only its baked-in knowledge and any information
# extracted from the Roon library, which may lead to more "hallucinated"
# or generic responses.
#
# Pick one provider and set its credential below. Recommended:
# Brave (free tier covers casual use, email + API key signup in
# under a minute). Tavily is a managed alternative. SearXNG is
# self-hosted via the Docker compose stack.
#
# Docker users: web-search settings here are IGNORED in the Docker
# stack — compose's ``environment:`` block forwards values from the
# top-level ``.env`` file instead (see the repo's ``.env.template``).
# Set WEB_SEARCH_PROVIDER, BRAVE_API_KEY, TAVILY_API_KEY, SEARXNG_URL
# there for Docker. The settings here only apply when running from source.
#
# WEB_SEARCH_PROVIDER must be set explicitly to enable web search:
#   "brave"   → requires BRAVE_API_KEY
#   "tavily"  → requires TAVILY_API_KEY
#   "searxng" → requires SEARXNG_URL (auto-configured for Docker
#               users running `docker compose --profile search`)
#   "none"    → web search disabled (same effect as leaving unset)
#
# If WEB_SEARCH_PROVIDER is unset, web search is disabled and the
# coordinator must answer external-knowledge queries from its
# baked-in knowledge alone — typically degraded responses.
# WEB_SEARCH_PROVIDER="brave"

# Brave Search — https://brave.com/search/api/
# BRAVE_API_KEY=""

# Tavily — https://tavily.com/
# TAVILY_API_KEY=""

# SearXNG (AGPL-3.0). Pulled from Docker Hub via
# `docker compose --profile search`; Swarpius does not redistribute it.
#   Docker compose users: leave SEARXNG_URL unset — compose injects
#   `http://searxng:8080` automatically when the agent service starts.
#   Run from source (agent running outside Docker, SearXNG in Docker):
#   set to `http://localhost:8888` (the host-side port mapped from
#   the searxng container).
#   External SearXNG instance: set to wherever it's reachable.
# SEARXNG_URL="http://localhost:8888"

# F5-TTS server address (TCP, scheme-less host:port). The agent uses
# this for CLI-mode speech AND proxies it to the browser over its own
# WebSocket — so one setting drives TTS for both modes. Leave unset
# (or empty) to disable TTS entirely.
#
# Docker users: TTS_URL here is IGNORED in the Docker stack — compose's
# ``environment:`` block forwards the value from the top-level ``.env``
# file instead (see the repo's ``.env.template``). The bundled
# tts-server service uses ``tts-server:9998`` as its hostname by
# default; set TTS_URL there only if pointing at an external server
# or disabling. The setting here only applies when running from source.
# TTS_URL="localhost:9998"

# ─────────────────────────────────────────────────────────────────────
# ADVANCED TUNING (safe defaults — most users do not need these)
# ─────────────────────────────────────────────────────────────────────

# Prompt caching — adds cache_control markers to system messages and
# tool definitions. Applied to Anthropic natively and to Gemini / Vertex
# via LiteLLM's cachedContents translation. OpenAI and DeepSeek cache
# automatically without markers, so this flag has no effect for them.
# Default on. Set to "false" only for debugging.
# ENABLE_PROMPT_CACHING="true"

# Run parallelisable tool calls concurrently within a step. Default off.
# PARALLEL_TOOLS="false"

# Maximum parallel Roon operations per step. Default 5 — keeps the
# Roon Core from dropping or stalling responses on big multi-track
# requests. Set to a positive integer to override; set to 0 (or any
# value < 1) for unlimited.
# ROON_MAX_PARALLEL="5"

# Roon search retry (for intermittent failures in Roon Search).
# ROON_SEARCH_RETRY_LIMIT="2"
# ROON_SEARCH_RETRY_DELAY="1.0"

# Title of the silent audio file in your Roon library that the `stop`
# transport action plays to end playback and clear the queue. See the
# "Stop relies on a user-installed silent marker" section in
# docs/known-limitations.md for setup.
# ROON_STOP_MARKER_TITLE="Swarpius_Stop_Playback"

# Hard opt-out for the simulated-stop feature. When true, the agent
# never tries to use the silent-marker workaround — every stop request
# via the coordinator agent just pauses, and the web client hides
# the stop button entirely. Use this if you don't want to install the
# marker file. Default false (feature engaged; web client shows a
# muted "verify availability" button until the marker is detected).
# DISABLE_SIMULATED_STOP="false"

# Context window tuning — useful for smaller/local models.
# CONVERSATION_HISTORY_MAX_TURNS="5"
# SEARCH_HISTORY_MAX_ENTRIES="5"
# EXECUTION_TRACE_MAX_LENGTH="10"

# Cache caps. Result store holds Q:-reference query results so they
# can be paginated/replayed; image cache holds zone artwork at the
# resolutions the frontend has requested. Both are LRU-evicted —
# raise if you have many active references / zones; lower for
# memory-constrained hosts.
# RESULT_STORE_MAX_ENTRIES="50"
# IMAGE_CACHE_MAX_ENTRIES="200"

# Conversation grouping — idle gap (seconds) that starts a new
# conversation thread in logs. Default 300.
# CONVERSATION_IDLE_TIMEOUT_SECONDS="300"

# Per-LLM-call timeout (seconds). Default 60.
# LLM_TIMEOUT_SECONDS="60"

# Conversations batched per analyser LLM call. Honoured by the
# background loop, the on-demand "Scan & Analyse" button, and the
# CLI analyser script. Default 5. Raise for faster throughput on
# large backlogs (watch provider context limits); lower for smaller
# prompts / tighter models.
# ANALYSER_BATCH_SIZE="5"

# Max versions of analysis-history.yaml retained per conversation
# before the oldest entries are rotated out. Default 20.
# ANALYSIS_HISTORY_MAX_ENTRIES="20"

# Location for mutable data (logs, config, messages DB, analysis).
# Default: agent/data/. Override for Docker / self-hosted deployments.
# SWARPIUS_DATA_DIR="/var/lib/swarpius"

# Server log file. Rotates at 10MB, keeps 3 backups. If unset, the
# agent writes to ``<SWARPIUS_DATA_DIR>/logs/swarpius.log`` by default
# in every mode (CLI, WS source, WS bundle, Docker). Set to override
# the path.
# LOG_FILE="logs/swarpius.log"

# Request/server log retention in days. Default 7.
# LOG_RETENTION_DAYS="7"

# WebSocket server bind (--ws mode only). Defaults to 127.0.0.1
# (loopback) — only the same machine can reach the agent. This is the
# safe default: the WebSocket has no authentication, so anyone who can
# reach it can drive the agent and read your API keys. To use Swarpius
# from another device on your LAN, read SECURITY.md first, and then
# set this to 0.0.0.0. Docker users: leave this unset; the compose file
# sets it, and host exposure is controlled by SWARPIUS_BIND_IP in the
# repo-root .env instead.
# SWARPIUS_WS_HOST="127.0.0.1"
# SWARPIUS_WS_PORT="8080"
