# Test-mode environment configuration — copied from
# `.env.test.template` to `.env.test` and edited locally. Read by
# `tests/conftest.py` *before* `.env`, so values here take precedence
# over `agent/.env` for the duration of the test run.
#
# Two purposes:
#
# 1. Override Roon connection settings when you want tests to point
#    at a different Core/zone than your day-to-day setup. Optional —
#    defaults are inherited from `agent/.env` if unset.
#
# 2. Configure per-library searches required by live Roon tests
#    (`pytest -m live_roon`). Every Roon library is different, so
#    there are no hardcoded defaults: each live test class declares
#    the `ROON_TEST_*` vars it needs and skips with a clear "Set X"
#    message when one is missing.
#
# Offline tests (the default `pytest`) need none of this.

# ─────────────────────────────────────────────────────────────────────
# Roon connection (optional — defaults inherited from agent/.env)
# ─────────────────────────────────────────────────────────────────────

# Override Roon Core URL for tests (e.g. point at a separate test
# Core, or use a Docker network hostname when running tests inside a
# container).
# ROON_CORE_URL="http://192.168.1.100:9330"

# Override the default zone tests act on. Useful if your day-to-day
# zone is in active use and you want tests to use a different one.
# DEFAULT_ROON_ZONE="Test Zone"

# Override the Roon profile.
# ROON_PROFILE_NAME="Swarpius"

# ─────────────────────────────────────────────────────────────────────
# Per-library searches (live Roon tests only — fill in or skip)
# ─────────────────────────────────────────────────────────────────────
#
# Each var below is required by one or more live test classes. Tests
# skip with a clear message when their required vars are missing, so
# you only need to set the ones for tests you want to run. Example
# values shown for guidance — replace with strings that match your
# library.

# General-purpose searches (multi-purpose; many tests use these)
# ROON_TEST_SEARCH_A=""    # e.g. "Beatles" — broadly-populated artist
# ROON_TEST_SEARCH_B=""    # e.g. "Mozart"  — different artist for cross-search/parallel tests
# ROON_TEST_SEARCH_C=""    # e.g. "Adele"   — third artist for three-way session tests

# Artist-specific Shuffle tests (test_shuffle_artist_live)
# ROON_TEST_ARTIST_A=""    # e.g. "Beatles"
# ROON_TEST_ARTIST_B=""    # e.g. "Rolling Stones"

# Playlist-action tests. Must be the exact name of a playlist in
# your Roon library.
# ROON_TEST_PLAYLIST=""              # e.g. "Favourites"
# ROON_TEST_EXPAND_PLAYLIST=""       # optional override for Shuffle-expand; falls back to ROON_TEST_PLAYLIST

# Album-action tests. Must match an album that has multiple versions
# in your library, to exercise version-disambiguation drilling.
# ROON_TEST_ALBUM=""    # e.g. "Thriller"

# Album→track category reconciliation tests
# (TestAlbumTopHitCategoryReconciliation in
# test_roon_browse_integration.py). The search's top hit must be an
# album that contains a same-titled track — i.e. drilling the top
# hit yields a gateway level [Play Album, ..., MatchingTrack, ...].
# Each intent (auto / album / track) is tested:
#   * auto, album → land on the Play Album action_list (no correction)
#   * track → reconcile triggers _correct_via_gateway_siblings, drills
#     into the same-titled track → returns the track's action_list
# ROON_TEST_GATEWAY_TRACK_SEARCH=""    # e.g. "Thriller Michael Jackson"
# ROON_TEST_GATEWAY_TRACK_TITLE=""     # e.g. "Thriller"

# Track→album category reconciliation tests
# (TestTrackTopHitCategoryReconciliation in
# test_roon_browse_integration.py). The search's top hit must be a
# *track* whose title matches an album in the library — drilling the
# top hit yields a track-shaped action_list, and the Albums category
# contains a same-titled album. The test asserts the corrected ref
# expands to real track refs that resolve to track-level menus.
# ROON_TEST_TRACK_ALBUM_SEARCH=""      # e.g. "Ram It Down Judas Priest"
# ROON_TEST_TRACK_ALBUM_TITLE=""       # e.g. "Ram It Down"

# Category-correction loud-failure tests
# (TestCategoryCorrectionLoudFailure). The search must produce a
# track-shaped top hit AND have no album/playlist with that title
# in the library — exercises both the album no_match branch (Albums
# present, no strict-titled album) and the playlist no_category
# branch (Playlists absent because search terms don't match a
# playlist's name).
# ROON_TEST_NO_CONTAINER_SEARCH=""    # e.g. "Voices Russ Ballard"
# ROON_TEST_NO_CONTAINER_TITLE=""     # e.g. "Voices"

# Track→playlist success test. Set to a search where (a) the top
# hit is track-shaped, (b) the Playlists category surfaces, and
# (c) a playlist titled identically to that top hit exists in your
# library. Example: search "enjoy the silence" with a same-titled
# playlist created in your library.
# ROON_TEST_PLAYLIST_TRACK_SEARCH=""

# Work-intent test (test_composer_work_validation_live's
# TestWorkIntentMatchesWorkRef). Must be a search that pins a
# Mozart-composed (or otherwise playable) Work as the FIRST entry
# in the Works category — bare composer names like "Mozart" don't
# work because Roon's Works category indexes by metadata, not just
# composer, and may surface unplayable / unrelated Works at the top.
# ROON_TEST_WORK_SEARCH=""    # e.g. "Mozart Piano Concerto No. 20"
