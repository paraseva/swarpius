#!/usr/bin/env bash
# Wrapper for running dev tools (pytest, ruff, python) under the WSL venv.
#
# Usage:
#   ./dev pytest                   # run full test suite
#   ./dev pytest tests/test_foo.py # run single test file
#   ./dev ruff check .             # lint
#   ./dev python -c "..."          # ad-hoc script
#
# Automatically activates .venv-wsl and fixes WSL tmp file issues.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="$SCRIPT_DIR/.venv-wsl"

if [ ! -d "$VENV_DIR" ]; then
    echo "Error: WSL venv not found at $VENV_DIR" >&2
    echo "Create it with: python3 -m venv $VENV_DIR && $VENV_DIR/bin/pip install -r requirements.txt" >&2
    exit 1
fi

# Fix WSL tmp file issue: pytest's capture plugin needs a native Linux
# tmp directory, not one on the Windows filesystem mount.
if [[ "$(uname -r)" == *microsoft* ]] && [[ -z "${TMPDIR:-}" || "$TMPDIR" == /mnt/* ]]; then
    for candidate in "/tmp/pytest-swarpius" "/tmp/claude-$(id -u)/pytest-swarpius"; do
        if mkdir -p "$candidate" 2>/dev/null; then
            export TMPDIR="$candidate"
            break
        fi
    done
fi

# Run the requested command through the venv
exec "$VENV_DIR/bin/$@"
