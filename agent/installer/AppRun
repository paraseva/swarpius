#!/bin/sh
# AppImage entry point. Re-exports HERE (the unpacked AppDir path) and
# execs the PyInstaller-built binary, forwarding all args. The bundle's
# runtime hook injects --ws unless the user explicitly overrides.
HERE="$(dirname "$(readlink -f "$0")")"
export PATH="$HERE/usr/bin:$PATH"
exec "$HERE/usr/bin/swarpius" "$@"
