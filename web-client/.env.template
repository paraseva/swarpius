# Web client environment overrides — copied from `.env.template` to
# `.env` and edited locally.
#
# All values are OPTIONAL. With nothing set, the client derives URLs
# from the browser's current host so it works out-of-the-box for
# typical setups (single-host install, browser on the same machine
# or LAN). Override only if your deployment doesn't fit that shape.

# ─────────────────────────────────────────────────────────────────────
# WebSocket URL
# ─────────────────────────────────────────────────────────────────────

# Agent WebSocket URL. Default: ws[s]://<browser-host>:8080/ws —
# protocol matches the page (ws on http, wss on https), host matches
# the address the browser is currently using to load the client.
#
# Set this only if the agent runs on a different host or non-default
# port. Loopback hosts (localhost, 127.0.0.1, ::1) in this value are
# auto-rewritten to the browser's hostname, so phone / LAN access
# still works when this is set to a localhost URL.
#
# TTS is served by the agent on the same host + port at /tts (the
# agent proxies to F5-TTS internally), so there's nothing separate
# to configure here.
# VITE_WS_URL="ws://localhost:8080/ws"
